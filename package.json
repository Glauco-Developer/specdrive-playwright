{
  "name": "mcp-aula",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal Playwright MCP boilerplate for URL-driven E2E tests",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "playwright test",
    "test:stable": "playwright test --grep @stable",
    "test:ci": "playwright test --grep @stable",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "report:open": "playwright show-report --host 127.0.0.1 --port 9323"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
